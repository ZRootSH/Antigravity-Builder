---
const currentYear = new Date().getFullYear();
---

<footer
  class="border-t border-slate-800/80 bg-slate-950/90 backdrop-blur-xl py-14 text-slate-400 relative overflow-hidden mt-auto"
>
  <!-- Subtle background glow -->
  <div
    class="absolute inset-0 bg-gradient-to-t from-neon-cyan/5 via-transparent to-transparent pointer-events-none"
  >
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div
      class="grid grid-cols-1 md:grid-cols-12 gap-10 pb-12 border-b border-slate-800/60"
    >
      <!-- Logo and Description -->
      <div class="md:col-span-4 flex flex-col space-y-4">
        <a href="/" class="flex items-center gap-2.5 group w-fit">
          <div
            class="w-8 h-8 rounded-lg bg-gradient-to-tr from-neon-cyan to-neon-purple p-0.5 shadow-neon-cyan transition-transform group-hover:scale-105"
          >
            <div
              class="w-full h-full bg-slate-950 rounded-[6px] flex items-center justify-center font-mono font-bold text-neon-cyan text-sm"
            >
              <img
                src="/favicon.svg"
                alt="Logo Antigravity IDE"
                class="w-6 h-6"
              />
            </div>
          </div>
          <span class="font-bold tracking-tight text-white text-base"
            >Antigravity <span class="text-gradient-cyan">IDE</span></span
          >
        </a>
        <p class="text-xs text-slate-400 leading-relaxed max-w-sm">
          Community repository and CI/CD packaging automation for native Fedora,
          RHEL, and AlmaLinux RPM packages. Built for developers by the Open
          Source community.
        </p>
      </div>

      <!-- Community and Project Links -->
      <div class="md:col-span-4 flex flex-col space-y-3">
        <h4
          class="text-xs font-mono font-semibold uppercase tracking-wider text-slate-200"
        >
          Community & Project
        </h4>
        <nav class="flex flex-col space-y-2 text-xs font-medium text-slate-400">
          <a
            href="/CHANGELOG.md"
            class="hover:text-neon-cyan transition-colors w-fit flex items-center gap-1.5"
          >
            <span class="text-neon-cyan/60">&rsaquo;</span> Changelog & Releases
          </a>
          <a
            href="/CONTRIBUTING.md"
            class="hover:text-neon-cyan transition-colors w-fit flex items-center gap-1.5"
          >
            <span class="text-neon-cyan/60">&rsaquo;</span> Contribution Guide
          </a>
          <a
            href="/CODE_OF_CONDUCT.md"
            class="hover:text-neon-cyan transition-colors w-fit flex items-center gap-1.5"
          >
            <span class="text-neon-cyan/60">&rsaquo;</span> Code of Conduct
          </a>
          <a
            href="/LICENSE"
            class="hover:text-neon-cyan transition-colors w-fit flex items-center gap-1.5"
          >
            <span class="text-neon-cyan/60">&rsaquo;</span> MIT License
          </a>
        </nav>
      </div>

      <!-- Sponsorship / Infrastructure (VERY IMPORTANT) -->
      <div class="md:col-span-4 flex flex-col justify-center">
        <div
          class="p-5 rounded-2xl bg-gradient-to-br from-slate-900/90 to-slate-950 border border-neon-cyan/20 shadow-lg shadow-neon-cyan/5 relative group hover:border-neon-cyan/40 transition-all duration-300"
        >
          <div
            class="absolute -top-2.5 left-4 px-2 py-0.5 bg-slate-900 border border-neon-cyan/30 rounded-full text-[10px] font-mono uppercase tracking-widest text-neon-cyan"
          >
            Infrastructure Partner
          </div>
          <p class="text-xs text-slate-300 mb-2 leading-relaxed mt-1">
            Server hosting, global bandwidth, and continuous deployment
            automation proudly provided by our official sponsor:
          </p>
          <div class="flex items-center gap-2 pt-1">
            <div class="w-2 h-2 rounded-full bg-neon-cyan animate-pulse"></div>
            <span
              class="text-sm font-extrabold tracking-wide text-transparent bg-clip-text bg-gradient-to-r from-neon-cyan via-teal-300 to-neon-purple group-hover:brightness-125 transition-all"
            >
              Hosted and Powered by ZrootSH - Solutions
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Copyright and Credits -->
    <div
      class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-slate-500 font-mono"
    >
      <div>
        &copy; {currentYear} Antigravity Linux Community. Distributed under MIT License.
      </div>
      <div class="flex items-center gap-4">
        <span>Fedora &bull; RHEL &bull; AlmaLinux</span>
        <span class="text-slate-700">|</span>
        <a href="/repo/" class="hover:text-slate-300 transition-colors"
          >/repo/ repomd.xml</a
        >
      </div>
    </div>
  </div>
</footer>
