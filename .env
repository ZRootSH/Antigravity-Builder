# ==============================================================================
# Antigravity IDE - Configuración de Entorno (.env)
# ==============================================================================

# 1. Variables para Docker Compose & repo-builder (Backend RPM / DevOps)
domain=antigravity.zrootsh.com
release=https://edgedl.me.gvt1.com/edgedl/release2/j0qc3/antigravity/stable/2.1.1-6123990880747520/linux-arm/Antigravity%20IDE.tar.gz
version=2.1.1
arch=aarch64

# 2. Variables PUBLIC_ para Astro/Vite & React (Frontend Web)
# Nota: Astro y Vite solo exponen al cliente (navegador) las variables que empiezan por PUBLIC_
PUBLIC_DOMAIN=antigravity.zrootsh.com
PUBLIC_VERSION=2.1.1
PUBLIC_ARCH=aarch64